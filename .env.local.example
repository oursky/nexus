# Copy this file to .env.local and fill in your values.
# .env.local is gitignored — never commit it.
#
# Used by Taskfile local tasks (dev:local, dev:cli, dev:swift) and scripts/local/*.sh

# ── Local dev defaults ──────────────────────────────────────────────────────
# Dev builds use a separate binary name, port, and state directory so they never
# collide with a production nexus daemon running on the same host.
#
# Prod uses:  ~/.local/bin/nexus          port 7777  state ~/.local/state/nexus/
# Dev uses:   ~/.local/bin/nexus-dev      port 7778  state ~/.local/state/nexus-dev/

# Local CLI binary path (default: ~/.local/bin/nexus-dev)
# LOCAL_BIN=~/.local/bin/nexus-dev

# Daemon port for dev (default: 7778)
# LOCAL_PORT=7778

# XDG_STATE_HOME override for dev state isolation.
# The daemon stores its DB, socket, and logs under $LOCAL_XDG_STATE_HOME/nexus.
# (default: ~/.local/state-dev — results in state dir ~/.local/state-dev/nexus/)
# LOCAL_XDG_STATE_HOME=~/.local/state-dev

# Workdir root for VM images (default: /data/nexus/nexus-dev)
# LOCAL_WORKDIR_ROOT=/data/nexus/nexus-dev

# ── Mac app build (SSH from Linux to Mac) ───────────────────────────────────
# Used by: task dev:swift, task dev:mac:build, task dev:mac:test-headless
#          scripts/remote/mac-build-app.sh  scripts/remote/mac-test-headless.sh
#          scripts/workspace-sync.sh
#
# Linux-first dev flow:
#   1. Source lives on this Linux host (inside a nexus process-sandbox workspace)
#   2. Changes are rsynced back to the Mac (MAC_HOST:MAC_REPO_ROOT)
#   3. NexusApp is built + opened on the Mac via SSH
#   4. Mac app is tested via headless RPC tunnelled from Mac → this Linux host
#
# SSH target of the Mac machine (user@hostname, e.g. newman@minion)
# MAC_HOST=newman@minion

# Repo root on the Mac that receives the rsync'd source (default: ~/magic/nexus)
# MAC_REPO_ROOT=~/magic/nexus
