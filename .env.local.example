# Copy this file to .env.local and fill in your values.
# .env.local is gitignored — never commit it.
#
# Used by Taskfile remote tasks (daemon:restart, daemon:token, deploy:remote, etc.)

# SSH target for your remote Linux dev box (user@hostname or user@ip)
REMOTE_HOST=user@hostname

# Remote path for the deployed nexus binary (default: ~/.local/bin/nexus)
# REMOTE_BIN=~/.local/bin/nexus

# Daemon port on the remote host (default: 7777)
# REMOTE_PORT=7777
