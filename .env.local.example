# Copy this file to .env.local and fill in your values.
# .env.local is gitignored — never commit it.
#
# Used by Taskfile remote tasks (dev:remote, dev:cli, dev:swift) and scripts/remote/*.sh

# SSH target for your remote Linux dev box (user@hostname or user@ip)
REMOTE_HOST=user@hostname

# ── Dev/prod separation ───────────────────────────────────────────────────────
# Dev builds use a separate binary name, port, and state directory so they never
# collide with a production nexus daemon running on the same remote host.
#
# Prod uses:  ~/.local/bin/nexus          port 7777  state ~/.local/state/nexus/
# Dev uses:   ~/.local/bin/nexus-dev      port 7778  state ~/.local/state/nexus-dev/
#
# Uncomment and adjust the values below to match your setup. The defaults shown
# here are the recommended dev conventions; prod operators should leave these
# commented out (the prod daemon is not managed by this Taskfile).

# Remote path for the deployed dev nexus binary (default: ~/.local/bin/nexus-dev)
# REMOTE_BIN=~/.local/bin/nexus-dev

# Daemon port on the remote host for dev (default: 7778)
# REMOTE_PORT=7778

# XDG_STATE_HOME override on the remote host for dev state isolation.
# The daemon stores its DB, socket, and logs under $REMOTE_XDG_STATE_HOME/nexus.
# (default: ~/.local/state-dev — results in state dir ~/.local/state-dev/nexus/)
# REMOTE_XDG_STATE_HOME=~/.local/state-dev

# Local CLI binary path (default: ~/.local/bin/nexus-dev)
# LOCAL_BIN=~/.local/bin/nexus-dev
