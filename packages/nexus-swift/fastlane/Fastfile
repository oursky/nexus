default_platform(:mac)

def resolve_build_number(options)
  bn = options[:build_number].to_s.strip
  return bn unless bn.empty?

  bn = Time.now.to_i.to_s
  UI.important("No build_number provided; using Unix timestamp #{bn}")
  bn
end

def get_git_commit_info
  {
    commit_hash: last_git_commit[:abbreviated_commit_hash],
    commit_message: last_git_commit[:message]
  }
end

platform :mac do
  variant = {
    'team_id' => 'M7HB6C3N6X',
    'apple_id' => '6762775351',
    'app_identifier' => 'com.oursky.nexus',
    'provisioning_profile' => 'signing/Nexus.provisionprofile',
    'provisioning_profile_name' => 'Nexus',
    'code_sign_identity' => 'Apple Distribution: Oursky Limited',
    'installer_sign_identity' => '3rd Party Mac Developer Installer: Oursky Limited (M7HB6C3N6X)',
    'project' => 'NexusApp.xcodeproj',
    'scheme' => 'NexusApp',
    'keychain_name' => 'nexus-build',
  }

  desc 'Build and upload the macOS app to TestFlight'
  lane :app_deploy do |options|
    app_build(options)
    app_testflight(options)
  end

  desc 'Build the macOS app for TestFlight'
  lane :app_build do |options|
    build_number = resolve_build_number(options)
    git_info = get_git_commit_info

    UI.message "Building Nexus macOS app"
    UI.message "Build: #{build_number}"
    UI.message "Commit: #{git_info[:commit_hash]}"
    UI.message "Message: #{git_info[:commit_message]}"

    keychain_password = SecureRandom.hex(16)

    create_keychain(
      name: variant['keychain_name'],
      password: keychain_password,
      default_keychain: true,
      unlock: true,
      timeout: 0,
    )

    import_certificate(
      certificate_path: 'signing/mac_installer.p12',
      certificate_password: '',
      keychain_name: variant['keychain_name'],
      keychain_password: keychain_password,
    )

    install_provisioning_profile(
      path: variant['provisioning_profile']
    )

    # ── Build with swift build (avoids xcodegen/xcodebuild SPM transitive C-target issues) ──
    version = get_version_number(xcodeproj: variant['project'], target: variant['scheme'])
    UI.message "Running swift build --configuration release..."
    sh("cd '#{File.dirname(__dir__)}' && swift build --package-path . -c release")

    # ── Create .app bundle ──
    build_dir = '.build/arm64-apple-macosx/release'
    app_name = variant['scheme']
    app_dir = "#{build_dir}/#{app_name}.app"
    contents = "#{app_dir}/Contents"
    macros_dir = "#{contents}/MacOS"
    resources_dir = "#{contents}/Resources"

    FileUtils.rm_rf(app_dir)
    FileUtils.mkdir_p(macros_dir)
    FileUtils.mkdir_p(resources_dir)

    # Copy executable
    binary = "#{build_dir}/#{app_name}"
    dest_binary = "#{macros_dir}/#{app_name}"
    FileUtils.cp(binary, dest_binary)
    FileUtils.chmod('+x', dest_binary)

    # Copy Resources from original project
    resources_src = 'Sources/NexusApp'
    if File.directory?(resources_src)
      Dir.glob("#{resources_src}/*.entitlements").each { |f| FileUtils.cp(f, resources_dir) }
      if File.directory?("#{resources_src}/Assets.xcassets")
        FileUtils.cp_r("#{resources_src}/Assets.xcassets", resources_dir)
      end
    end

    # Copy resource files next to binary
    Dir.glob('.build/arm64-apple-macosx/release/*.bundle').each do |bundle|
      FileUtils.cp_r(bundle, resources_dir)
    end

    # Copy provisioning profile
    profile_dest = "#{contents}/embedded.provisionprofile"
    FileUtils.cp(variant['provisioning_profile'], profile_dest)

    # Write Info.plist
    File.write("#{contents}/Info.plist", <<~PLIST)
      <?xml version="1.0" encoding="UTF-8"?>
      <!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
      <plist version="1.0">
      <dict>
        <key>CFBundleExecutable</key>
        <string>#{app_name}</string>
        <key>CFBundleIdentifier</key>
        <string>#{variant['app_identifier']}</string>
        <key>CFBundleName</key>
        <string>#{app_name}</string>
        <key>CFBundlePackageType</key>
        <string>APPL</string>
        <key>CFBundleShortVersionString</key>
        <string>#{version}</string>
        <key>CFBundleVersion</key>
        <string>#{build_number}</string>
        <key>LSMinimumSystemVersion</key>
        <string>14.0</string>
      </dict>
      </plist>
    PLIST

    # Write entitlements for codesign
    entitlements_src = 'Sources/NexusApp/NexusApp.entitlements'
    unless File.exist?(entitlements_src)
      entitlements_src = 'Sources/NexusApp/nexus.entitlements'
    end
    if File.exist?(entitlements_src)
      FileUtils.cp(entitlements_src, "#{contents}/app.entitlements")
    else
      UI.important "No entitlements file found; signing without entitlements"
    end

    # ── Code sign the .app ──
    UI.message "Code signing #{app_name}.app..."
    sign_args = [
      '--force',
      '--timestamp',
      '--options=runtime',
      '--sign', "'#{variant['code_sign_identity']}'",
      '--keychain', "'#{ENV['HOME']}/Library/Keychains/#{variant['keychain_name']}-db'",
      '--generate-entitlement-der'
    ]
    if File.exist?("#{contents}/app.entitlements")
      sign_args += ['--entitlements', "#{contents}/app.entitlements"]
    end
    sh("codesign #{sign_args.join(' ')} '#{app_dir}'")

    # ── Create .pkg ──
    pkg_name = "#{app_name}-#{version}-#{build_number}.pkg"
    UI.message "Creating installer package: #{pkg_name}"
    sh("productbuild --component '#{app_dir}' /Applications --sign '#{variant['installer_sign_identity']}' --keychain '#{ENV['HOME']}/Library/Keychains/#{variant['keychain_name']}-db' '#{pkg_name}'")

    UI.success "#{pkg_name} created"
  end

  desc 'Build and notarize a DMG for direct distribution'
  lane :app_dmg do |options|
    build_number = resolve_build_number(options)
    git_info = get_git_commit_info

    UI.message "Building Nexus macOS DMG"
    UI.message "Build: #{build_number}"
    UI.message "Commit: #{git_info[:commit_hash]}"
    UI.message "Message: #{git_info[:commit_message]}"

    UI.user_error!('APP_STORE_CONNECT_API_KEY_FILE is not set') if ENV['APP_STORE_CONNECT_API_KEY_FILE'].to_s.empty?

    api_key_file = ENV['APP_STORE_CONNECT_API_KEY_FILE']
    api_key = JSON.parse(File.read(api_key_file))
    key_id = api_key['key_id']
    issuer_id = api_key['issuer_id']
    key = api_key['key']

    keychain_password = SecureRandom.hex(16)

    create_keychain(
      name: variant['keychain_name'],
      password: keychain_password,
      default_keychain: true,
      unlock: true,
      timeout: 0,
    )

    # Import Developer ID Application certificate (for direct distribution)
    dev_id_path = 'signing/developer_id_app.p12'
    if File.exist?(dev_id_path)
      UI.message "Importing Developer ID Application certificate"
      import_certificate(
        certificate_path: dev_id_path,
        certificate_password: '',
        keychain_name: variant['keychain_name'],
        keychain_password: keychain_password,
      )
    else
      UI.important "Developer ID Application certificate not found at #{dev_id_path}"
      UI.important "Build may fail if certificate is not in system keychain"
    end

    # Import Mac Installer certificate (fallback)
    import_certificate(
      certificate_path: 'signing/mac_installer.p12',
      certificate_password: '',
      keychain_name: variant['keychain_name'],
      keychain_password: keychain_password,
    )

    install_provisioning_profile(
      path: variant['provisioning_profile']
    )

    build_mac_app(
      project: variant['project'],
      scheme: variant['scheme'],
      configuration: 'Release',
      export_method: 'developer-id',
      skip_package_pkg: true,
      export_options: {
        provisioningProfiles: {
          variant['app_identifier'] => variant['provisioning_profile_name'],
        },
      },
      xcargs: "CURRENT_PROJECT_VERSION=#{build_number} MARKETING_VERSION=#{get_version_number(xcodeproj: variant['project'], target: variant['scheme'])} SWIFT_STRICT_CONCURRENCY=minimal NEXUS_APP_BUNDLE_ID=#{variant['app_identifier']} CODE_SIGN_STYLE=Manual DEVELOPMENT_TEAM=#{variant['team_id']} CODE_SIGN_IDENTITY='Developer ID Application: Oursky Limited (M7HB6C3N6X)'"
    )

    app_path = File.join(output_dir, "#{scheme}.app")

    dist_dir = File.join(File.dirname(__dir__), 'dist')
    FileUtils.mkdir_p(dist_dir)

    version = get_version_number(xcodeproj: variant['project'], target: variant['scheme'])
    dmg_name = "Nexus-#{version}-#{build_number}.dmg"
    dmg_path = File.join(dist_dir, dmg_name)

    UI.message "Creating DMG: #{dmg_path}"

    temp_dmg = File.join(dist_dir, 'temp.dmg')
    app_name = File.basename(app_path)
    volume_name = "Nexus #{version}"

    sh("hdiutil create -srcfolder '#{app_path}' -volname '#{volume_name}' -fs HFS+ -format UDRW -size 100m '#{temp_dmg}'")
    sh("hdiutil convert '#{temp_dmg}' -format UDZO -o '#{dmg_path}'")
    FileUtils.rm_f(temp_dmg)

    UI.message "Notarizing DMG..."

    key_file = File.join(dist_dir, 'AuthKey.p8')
    File.write(key_file, key)

    begin
      sh("xcrun notarytool submit '#{dmg_path}' --key '#{key_file}' --key-id '#{key_id}' --issuer '#{issuer_id}' --wait")
      sh("xcrun stapler staple '#{dmg_path}'")
      UI.success "DMG created and notarized: #{dmg_path}"
    ensure
      FileUtils.rm_f(key_file)
    end

    dmg_path
  end

  desc 'Upload the macOS app to TestFlight'
  lane :app_testflight do |options|
    build_number = resolve_build_number(options)
    git_info = get_git_commit_info
    pkg_path = options[:pkg] || Actions.lane_context[SharedValues::PKG_OUTPUT_PATH] || Dir[File.join(File.dirname(__dir__), '*.pkg')].max_by { |f| File.mtime(f) }

    UI.user_error!('APP_STORE_CONNECT_API_KEY_FILE is not set') if ENV['APP_STORE_CONNECT_API_KEY_FILE'].to_s.empty?
    UI.user_error!('No macOS package found for TestFlight upload') if pkg_path.nil?

    UI.message "Uploading Nexus macOS app to TestFlight"
    UI.message "Build: #{build_number}"
    UI.message "Commit: #{git_info[:commit_hash]}"
    UI.message "Message: #{git_info[:commit_message]}"

    changelog = "Build #{build_number}\nCommit: #{git_info[:commit_hash]}\nMessage: #{git_info[:commit_message]}"

    upload_to_testflight(
      pkg: pkg_path,
      apple_id: variant['apple_id'],
      app_identifier: variant['app_identifier'],
      team_id: variant['team_id'],
      api_key_path: ENV['APP_STORE_CONNECT_API_KEY_FILE'],
      skip_waiting_for_build_processing: true,
      beta_app_description: changelog,
      changelog: changelog
    )
  end

  after_all do |lane, options|
    delete_keychain(name: variant['keychain_name']) rescue nil
  end

  error do |lane, exception, options|
    delete_keychain(name: variant['keychain_name']) rescue nil
  end
end
